# ═══════════════════════════════════════════════════════════════
# The Case File — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy: cp .env.example .env  then fill in your values.
# NEVER commit the real .env to git.
# ═══════════════════════════════════════════════════════════════

# ── Groq API Key (required) ────────────────────────────────────
# Free key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ── LLM Model ─────────────────────────────────────────────────
LLM_MODEL=llama-3.3-70b-versatile
LLM_PROVIDER=groq
LLM_API_KEY=your_groq_api_key_here

# ── Cognee Cloud (optional — leave blank to run locally) ───────
# Sign up at: https://platform.cognee.ai
# If set, ALL memory operations route to Cognee Cloud instead of local SQLite.
# This gives you persistent cross-session memory that survives server restarts.
COGNEE_SERVICE_URL=
COGNEE_API_KEY=

# ── Embeddings ────────────────────────────────────────────────
EMBEDDING_PROVIDER=local

# ── Case namespace ─────────────────────────────────────────────
CASE_ID=case-2024-alpha-7

# ── Server ────────────────────────────────────────────────────
PORT=8000
DEV_RELOAD=true
CORS_ORIGINS=*

# ── Cognee flags ──────────────────────────────────────────────
COGNEE_SKIP_CONNECTION_TEST=true
